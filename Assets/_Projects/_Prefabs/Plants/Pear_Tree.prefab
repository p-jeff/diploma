      value: 1.2
      objectReference: {fileID: 0}
    - target: {fileID: 5122842465899161861, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_text
      value: "Birnenschmaus\n\nSo come, dear sunshine,\nMake our pears grow well!\nAnd
        when they have turned golden,\nThen come and blow, dear wind!\nCome, wind,
        and rustle every branch\nAnd invite us all to be your guests!\nWe will hurry
        out of the house\nAnd hold a pear feast.\n\n\u2014 August Heinrich Hoffmann
        von Fallersleben"
      objectReference: {fileID: 0}
    - target: {fileID: 5122842465899161861, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_TextStyleHashCode
      value: -1183493901
      objectReference: {fileID: 0}
    - target: {fileID: 5902464882853280731, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: instanceId
      value: 1760b5f8-68e5-4aa4-802b-ab8ec9134e77
      objectReference: {fileID: 0}
    - target: {fileID: 6181259333930047258, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: GsplatAsset
      value: 
      objectReference: {fileID: 4599839170941234424, guid: 90b778b69477e5049bda41faf128fb84, type: 3}
    - target: {fileID: 6181259333930047258, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_assetGuid
      value: 90b778b69477e5049bda41faf128fb84
      objectReference: {fileID: 0}
    - target: {fileID: 6835627233580907840, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_Sprite
      value: 
      objectReference: {fileID: 21300000, guid: 5ba5244fb6972b140bd03818a6af1232, type: 3}
    - target: {fileID: 7173199714940506848, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_text
      value: "Pear, French Cuisine\nLouis XIV named the pear a royal fruit, and his
        obsession was sincere. It was his greatest fruit love after figs \u2014 his
        gardener La Quintinie raised fifty varieties for the royal table, and Louis
        sent his favourite, the Bon Chr\xE9tien, as gifts to other heads of state.
        It entered French haute cuisine and has never left."
      objectReference: {fileID: 0}
    - target: {fileID: 7173199714940506848, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_TextStyleHashCode
      value: -1183493901
      objectReference: {fileID: 0}
    - target: {fileID: 7417057368276200879, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_Sprite
      value: 
      objectReference: {fileID: 21300000, guid: 05c457be520bc80429e53f44ea9d220c, type: 3}
    - target: {fileID: 8810918796485297829, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_Sprite
      value: 
      objectReference: {fileID: 21300000, guid: f6c9265a3b443f0438cc237b4aef34bc, type: 3}
    - target: {fileID: 9161542878112791018, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_text
      value: "Les Adeuineax amoreux\nTrois moines passoient\nTrois poires pendoient\nChascum
        en prist une\nEt s\u2019en demouras deux.\nL\u2019Explication: L\u2019un
        des moines avoit nom Chascun.\n\nThree monks were passing\nThree pears were
        hanging\nEach took one\nAnd two remained.\n\nExplanation: One of the monks
        was named Each"
      objectReference: {fileID: 0}
    - target: {fileID: 9161542878112791018, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_TextStyleHashCode
      value: -1183493901
      objectReference: {fileID: 0}
