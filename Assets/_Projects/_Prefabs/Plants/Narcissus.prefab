    - target: {fileID: 5956918439778082410, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_text
      value: 'In order to see the greenery and the rose

        God has given the
        eye of the narcissus the power of seeing.


        Mirza Ghalib'
      objectReference: {fileID: 0}
    - target: {fileID: 5956918439778082410, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
