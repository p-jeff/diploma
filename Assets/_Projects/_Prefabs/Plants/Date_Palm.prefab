    - target: {fileID: 2636065031202590820, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_text
      value: "\"Psalm 92-12\n12 The righteous will flourish like a palm tree,\nthey
        will grow like a cedar of Lebanon;\n13 planted in the house of the Lord,\nthey
        will flourish in the courts of our God.\n14 They will still bear fruit in
        old age,\nthey will stay fresh and green,\n15 proclaiming, \u201CThe Lord
        is upright;\nhe is my Rock, and there is no wickedness in him.\u201D\""
      objectReference: {fileID: 0}
