      objectReference: {fileID: 21300000, guid: 1c62a68419e689246a23444a793c1761, type: 3}
    - target: {fileID: 9161542878112791018, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_text
      value: "## Crocus, Minoans\nThe Minoans were a Bronze Age civilization centered
        on Crete and the Cyclades (c. 2000\u20131400 BCE), known for their palace
        complexes, vivid frescoes, and far-reaching Aegean trade. Among their art,
        the crocus held notable cultural relevance, likely due to the many-layered
        value of saffron, used as dye, medicine, colorant, and possibly a ritual
        substance, and its consistent links to women, animals, and a likely deity,
        suggesting it was woven deep into Minoan myth and identity. Today it survives
        mainly in their frescoes and pottery.\n\n![[_Die_Fresken_von_Akrotiri_z\xE4hlen_zu_den_spektakul\xE4rsten_Zeugen_der_Bronzezeit.__11.jpg]]\nhttps://commons.wikimedia.org/wiki/Category:Saffron_gatherers_(Akrotiri)"
      objectReference: {fileID: 0}
    - target: {fileID: 9161542878112791018, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_TextStyleHashCode
      value: -1183493901
      objectReference: {fileID: 0}
    m_RemovedComponents: []
    m_RemovedGameObjects:
