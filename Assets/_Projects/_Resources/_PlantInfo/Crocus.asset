  m_Name: Crocus
  m_EditorClassIdentifier: Assembly-CSharp::Plants.PlantData
  displayName: Crocus
  audioClip: {fileID: 8300000, guid: c55406d37660fab4d9c2635682ca0db7, type: 3}
  environmentPainting: {fileID: 0}
  environmentLayers: []
  environmentVerticalOffset: 0
  poem:
    text: "The Crocus's Soliloquy\n\nDown in my solitude under the snow, \nWhere
      nothing cheering can reach me; \nHere, without light to see how to grow, \nI'll
      trust to nature to teach me. \nSoon as the frost will get out of my bed, \nFrom
      this cold dungeon to free me \n,I will peer up with my little bright head;
      \nAll will be joyful to see me. \nMany, perhaps, from so simple a flower \nThis
      little lesson may borrow \u2014 \nPatient to-day, through its gloomiest hour,
      \nWe come out the brighter to-morrow.\n\nHannah Flagg Gould"
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  contextInfos:
  - text: 'Crocus was a young mortal, who was in love with the Nymph Smilax. Either
      the love was not returned, or no love was possible between mortal and nymph,
      leading to the gods taking pity upon Crocus, turning him into the saffron flower
      as a relief for his grief."

'
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  - text: 'Crocuses are the first flowers that grow in spring in many parts of the
      world

'
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  - text: "Saffron \"Red Gold\" the worlds costliest spice, is harvested from the
      crocus sativus. \r\n"
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  - text: 'Each plant yields only 3 stigmata, which make up the spice. It needs over
      150.000 Flowers for 1kg

'
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  - text: "The Minoans were a Bronze Age civilization centered on Crete (c. 2000\u20131400
      BCE), known for their palace complexes, vivid frescoes, and far-reaching Aegean
      trade. Among their art, the crocus held notable cultural relevance.\r\n"
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  - text: "The Minoans were a Bronze Age civilization centered on Crete (c. 2000\u20131400
      BCE), known for their palace complexes, vivid frescoes, and far-reaching Aegean
      trade. Among their art, the crocus held notable cultural relevance.\r\n"
