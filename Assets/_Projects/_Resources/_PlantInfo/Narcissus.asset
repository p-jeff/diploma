MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3e1cd92da80c7495a8fe7eb91fa80c2f, type: 3}
  m_Name: Narcissus
  m_EditorClassIdentifier: Assembly-CSharp::Plants.PlantData
  displayName: Narcissus
  audioClip: {fileID: 8300000, guid: 76a867b71ee24944e87fba3a06f1676c, type: 3}
  environmentPainting: {fileID: 0}
  environmentLayers: []
  environmentVerticalOffset: 0
  poem:
    text: "Behold all the world's gardens and see \nthe traces of God's craft: \nwhere
      eyes of silver gaze on high, \nwith pupils made of molten gold, \non emerald
      stalks they testify \nthat God acknowledges no equal\n\nAbu Nuwas"
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  contextInfos:
  - text: 'Daffodils have likely been the first flowers to be cultivated only for
      their beauty. '
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  - text: 'In ancient Persia, they were likened to eyes, while in ancient Greece,
      their beauty inspired the story of Narcissus '
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  - text: 'Narcissus was the most beautiful. He rejected advances of all whom admired,
      so one asked him to be cursed. So he was, cursed to fall in love with him own
      reflection in a pool of water. He perished in agoning and longing, turning
      into the Daffodil. '
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
  - text: 'In order to see the greenery and the rose

      God has given the eye
      of the narcissus the power of seeing.


      Mirza Ghalib'
    contextImage: {fileID: 0}
    imageWidth: 0.5
    imageFeather: -1
    environmentPainting: {fileID: 0}
    environmentLayers: []
    environmentVerticalOffset: 0
