    - target: {fileID: 1501860828498610035, guid: ed7b740a5cf36044ab197a19d1fe05ab, type: 3}
      propertyPath: m_text
      value: "Better to eat without meat than to live without bamboo. / Without meat,
        one merely grows thin; without bamboo, one grows vulgar. / Thinness can still
        be remedied \u2014 vulgarity in a scholar cannot be cured"
      objectReference: {fileID: 0}
